# Copy to `.env` (gitignored) and fill in real values.
# Read at build time by the Pico W firmware (firmware/pico-partybutton/build.rs)
# and baked into the flashed binary.

# Wifi the Pico W joins (WPA2).
WIFI_SSID=your-network
WIFI_PASSWORD=your-password

# Party key — must match the PARTY_KEY secret set on the Cloudflare Worker.
# Sent as `Authorization: Bearer <key>` on the toggle request.
PARTY_API_KEY=your-party-key

# Optional. Defaults to https://partybutton.recurse.com
PARTY_API_BASE=https://partybutton.recurse.com
